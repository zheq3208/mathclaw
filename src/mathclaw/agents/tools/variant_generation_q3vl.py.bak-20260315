    "variant_type": "isomorphic|easier|harder",
    "problem_text": "str",
    "changes": ["str"],
    "intent": "str",
    "difficulty_goal": "same|easier|harder",
    "coach_note": "str",
    "answer_outline": ["str"],
}

_DRAFT_SCHEMA = {
    "variant_set_title": "str",
    "variants": [_VARIANT_ITEM_SCHEMA],
    "design_notes": ["str"],
}

_DRAFT_PROMPT = """
你是数学学习系统中的“变式题设计器”。
请围绕原题生成后续练习题，帮助学生迁移与巩固。
要求：
- 只返回一个 JSON 对象。
- 所有自然语言字段必须使用简体中文。
