        if not source:
            return None
        self._mark_turn_route('exam_pipeline')
        logger.info('[ExamPipeline] session=%s message=%s', session_id or '', str(message or '')[:120])
        try:
            ocr_payload = self._tool_response_json(
                self._invoke_tool(
                    'extract_math_document',
