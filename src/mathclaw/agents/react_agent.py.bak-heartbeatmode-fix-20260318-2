    def _maybe_handle_variant_generation_request(
        self,
        message: str,
        *,
        attachments: list[dict[str, Any]] | None = None,
        session_id: str | None = None,
        store_response: bool = True,
    ) -> str | None:
        if 'run_problem_variant_agent' not in self._tools:
